# Server Port (default: 3210). If busy, the server will try PORT+1 through PORT+10.
PORT=3210

# Database Mode
# Set to true to use in-memory SQLite instead of on-disk (default: false)
IN_MEMORY_DB=false

# Qdrant Vector Search (optional — omit to disable vector search)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# OpenAI Embeddings (required alongside QDRANT_URL to enable vector search)
OPENAI_API_KEY=

# Vector Search Tuning
QDRANT_MIN_SCORE=0.6
EMBEDDING_BATCH_DELAY_MS=1

# IMPORTANT: Qdrant requires an OPEN_AI key (or in the future any provider, since we can switch via using Vercel AI SDK).
SKIP_STARTUP_UPDATING_QDRANT=true
DO_NOT_USE_QDRANT=true

# AI Topic Summarization
# IMPORTANT: Summarization requires an OPEN_AI key (or in the future any provider, since we can switch via using Vercel AI SDK).
# Set to false to enable GPT-5-nano summaries for all threads at startup (default: true = disabled)
SKIP_AI_SUMMARIZATION=true
AI_SUMMARIZATION_MODEL_PASS_1=gpt-5-nano
AI_SUMMARIZATION_MODEL_PASS_2=gpt-5-mini

# Search Configuration
# Fuse.js threshold: 0.0 = exact match, 1.0 = match anything (default: 0.4)
FUSE_THRESHOLD=0.4
# Disable search response cache for debugging (default: false)
DISABLE_SEARCH_CACHE=false

# MCP Configuration
# Master switch for MCP server startup (stdio + optional SSE)
MCP_ENABLED=true
MCP_LOGGING=true
# SSE transport is opt-in (default: disabled)
MCP_SSE_ENABLED=false
# Optional bearer token required for /mcp/sse and /mcp/messages when set
MCP_AUTH_TOKEN=